## ============================================
## SimpleSST - Variáveis de Ambiente (Produção)
## ============================================
## Copie este arquivo para ../.env e preencha
## ============================================

## SETTINGS
APP_HOST=https://simplesst.com.br
PORT=3333
NODE_ENV=production

## DATABASE (PostgreSQL rodando em Docker, acesso via localhost)
DATABASE_USER=postgres
DATABASE_PASSWORD=SUA_SENHA_FORTE_AQUI
DATABASE_NAME=postgres
DATABASE_PORT=5432
DATABASE_HOST=localhost
DATABASE_URL="postgresql://postgres:SUA_SENHA_FORTE_AQUI@localhost:5432/postgres?schema=public&pool_timeout=0"

## AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_BUCKET_REGION=us-east-1
AWS_SQS_REGION=us-east-1

## SQS
AWS_SQS_PGR_URL=
AWS_SQS_EMAIL_URL=
AWS_SQS_NOTIFICATION_URL=

## AUTH
TOKEN_SECRET=GERE_UM_TOKEN_SECRETO_FORTE
REFRESH_TOKEN_SECRET=GERE_OUTRO_TOKEN_SECRETO_FORTE
TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=3h

## SENDGRID
SENDGRID_API_KEY=

## FIREBASE
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

## OPENAI (SimpleSST — formulários / IA)
OPENAI_API_KEY=
# Fontes geradoras e recomendações por par (ai-analyze-risks). Fallback do adapter: o4-mini.
OPENAI_MODEL=o4-mini
# Diagnóstico narrativo FRPS/PGR (risk-narrative-diagnostic). Fallback em código: gpt-5.
OPENAI_RISK_NARRATIVE_MODEL=gpt-5
# Diagnóstico narrativo Indicadores (indicators-narrative-diagnostic). Fallback em código: gpt-4o-mini.
OPENAI_INDICATORS_NARRATIVE_MODEL=gpt-4o-mini
# Alternativa: gpt-4.1 se a chave/projeto não tiver acesso ao GPT-5.

## TELEGRAM
TELEGRAM_TOKEN=

## ESOCIAL
ESOCIAL_URL_PROD=https://webservices.envio.esocial.gov.br/servicos/empregador/enviarloteeventos/WsEnviarLoteEventos.svc?wsdl
ESOCIAL_URL_PROD_RESTRICT=https://webservices.producaorestrita.esocial.gov.br/servicos/empregador/enviarloteeventos/WsEnviarLoteEventos.svc?wsdl
TRANSMISSION_PFX_PASSWORD=

