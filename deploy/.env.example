## ============================================
## SimpleSST - Variáveis de Ambiente (Produção)
## ============================================
## Copie este arquivo para ../.env e preencha
## ============================================

## SETTINGS
APP_HOST=https://simplesst.com.br
PORT=3333
NODE_ENV=production

## DATABASE (PostgreSQL local no Docker)
DATABASE_USER=simplesst_user
DATABASE_PASSWORD=SUA_SENHA_FORTE_AQUI
DATABASE_NAME=simplesst_db
DATABASE_PORT=5432
DATABASE_HOST=db
DATABASE_URL="postgresql://simplesst_user:SUA_SENHA_FORTE_AQUI@db:5432/simplesst_db?schema=public&pool_timeout=0"

## AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_BUCKET_REGION=us-east-1
AWS_SQS_REGION=us-east-1

## SQS
AWS_SQS_PGR_URL=
AWS_SQS_EMAIL_URL=
AWS_SQS_NOTIFICATION_URL=

## AUTH
TOKEN_SECRET=GERE_UM_TOKEN_SECRETO_FORTE
REFRESH_TOKEN_SECRET=GERE_OUTRO_TOKEN_SECRETO_FORTE
TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=3h

## SENDGRID
SENDGRID_API_KEY=

## FIREBASE
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

## TELEGRAM
TELEGRAM_TOKEN=

## ESOCIAL
ESOCIAL_URL_PROD=https://webservices.envio.esocial.gov.br/servicos/empregador/enviarloteeventos/WsEnviarLoteEventos.svc?wsdl
ESOCIAL_URL_PROD_RESTRICT=https://webservices.producaorestrita.esocial.gov.br/servicos/empregador/enviarloteeventos/WsEnviarLoteEventos.svc?wsdl
TRANSMISSION_PFX_PASSWORD=

